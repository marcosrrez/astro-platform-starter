---
import Logo from '../components/Logo.astro';

const navItems = [
    { linkText: 'Home', href: '/' },
    { linkText: 'Research', href: '/blog' },
    { linkText: 'Resources', href: '/resources' },
    { linkText: 'About', href: '/about' },
    { linkText: 'Newsletter', href: '/newsletter' }
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
    href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="flex items-center justify-between gap-4 pt-6 pb-8 sm:pt-8 sm:pb-12">
    <a href="/" class="hover:opacity-80 transition-opacity shrink-0" aria-label="Florecer Mind home">
        <Logo />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden sm:block" aria-label="Primary">
        <ul class="flex flex-wrap items-center gap-x-1 gap-y-1">
            {navItems.map((item) => (
                <li>
                    <a
                        href={item.href}
                        aria-current={isActive(item.href) ? 'page' : undefined}
                        class={`inline-flex items-center min-h-[44px] px-3 font-sans font-medium transition-colors ${
                            isActive(item.href)
                                ? 'text-primary'
                                : 'text-neutral-700 hover:text-primary'
                        }`}
                    >
                        <span class={isActive(item.href) ? 'border-b-2 border-primary pb-0.5' : 'border-b-2 border-transparent pb-0.5'}>
                            {item.linkText}
                        </span>
                    </a>
                </li>
            ))}
        </ul>
    </nav>

    <!-- Mobile nav (disclosure menu) -->
    <details class="sm:hidden relative group">
        <summary
            class="list-none flex items-center justify-center min-h-[44px] min-w-[44px] cursor-pointer text-neutral-800 rounded-lg hover:bg-neutral-100 transition-colors"
            aria-label="Open menu"
        >
            <svg class="w-6 h-6 group-open:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg class="w-6 h-6 hidden group-open:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </summary>
        <nav
            class="absolute right-0 top-full z-50 mt-2 w-56 rounded-lg border border-neutral-200 bg-[#FAFAF9] shadow-xl overflow-hidden"
            aria-label="Primary"
        >
            <ul class="flex flex-col py-1">
                {navItems.map((item) => (
                    <li>
                        <a
                            href={item.href}
                            aria-current={isActive(item.href) ? 'page' : undefined}
                            class={`flex items-center min-h-[44px] px-4 font-sans font-medium transition-colors ${
                                isActive(item.href)
                                    ? 'text-primary bg-primary/5'
                                    : 'text-neutral-700 hover:bg-neutral-100'
                            }`}
                        >
                            {item.linkText}
                        </a>
                    </li>
                ))}
            </ul>
        </nav>
    </details>
</header>
