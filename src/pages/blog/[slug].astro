---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SocialShare from '../../components/SocialShare.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';

export async function getStaticPaths() {
    const blogEntries = await getCollection('blog');
    return blogEntries.map(entry => ({
        params: { slug: entry.slug },
        props: { entry }
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Editorial metadata
const reviewer = 'Marcos Gutierrez';
const reviewerCredential = 'LAC'; // Licensed Associate Counselor
const readingTime = Math.max(1, Math.round(entry.body.split(/\s+/).filter(Boolean).length / 200));
const sourceCount = entry.data.sources?.length ?? 0;
const formatDate = (d: Date) =>
    d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Structured data for SEO
const structuredData = {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.description,
    image: entry.data.image ? new URL(entry.data.image, Astro.site).toString() : new URL('/og-default.png', Astro.site).toString(),
    datePublished: entry.data.pubDate.toISOString(),
    dateModified: entry.data.pubDate.toISOString(),
    author: {
        '@type': 'Organization',
        name: 'Florecer Mind',
        url: Astro.site
    },
    editor: {
        '@type': 'Person',
        name: reviewer,
        jobTitle: 'Licensed Associate Counselor'
    },
    publisher: {
        '@type': 'Organization',
        name: 'Florecer Mind',
        logo: {
            '@type': 'ImageObject',
            url: new URL('/favicon.svg', Astro.site).toString()
        }
    },
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': new URL(Astro.url.pathname, Astro.site).toString()
    },
    articleSection: entry.data.category,
    keywords: entry.data.tags.join(', ')
};
---

<Layout
    title={entry.data.title}
    description={entry.data.description}
    article={true}
    publishedTime={entry.data.pubDate.toISOString()}
    author={entry.data.author || "Florecer Mind Research Team"}
    image={entry.data.image || "/og-default.png"}
    imageAlt={`${entry.data.title} - Florecer Mind`}
>
    <article class="mx-auto max-w-[46rem]">
        <!-- Article Header -->
        <header class="mb-10">
            <a href={`/blog?category=${encodeURIComponent(entry.data.category)}`} class="kicker">
                {entry.data.category}
            </a>

            <h1 class="mt-4 mb-5 optical-align">
                {entry.data.title}
            </h1>

            <p class="mb-8 font-serif text-2xl leading-snug text-neutral-700">
                {entry.data.description}
            </p>

            <!-- Byline & meta -->
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 article-meta">
                <span>By <span class="font-medium text-neutral-800">Florecer Mind</span></span>
                <span aria-hidden="true">·</span>
                <span>Reviewed by <span class="font-medium text-neutral-800">{reviewer}, {reviewerCredential}</span></span>
                <span aria-hidden="true">·</span>
                <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
                <span aria-hidden="true">·</span>
                <span>{readingTime} min read</span>
                {sourceCount > 0 && (
                    <>
                        <span aria-hidden="true">·</span>
                        <span>{sourceCount} peer-reviewed {sourceCount === 1 ? 'source' : 'sources'}</span>
                    </>
                )}
            </div>

            <hr class="mt-8 border-neutral-200" />
        </header>

        <!-- Article Content -->
        <div class="prose prose-lg max-w-none">
            <Content />
        </div>

        <!-- Newsletter CTA -->
        <NewsletterCTA />

        <!-- Sources & Resources Section -->
        {(entry.data.sources || entry.data.furtherReading || entry.data.relatedVideos) && (
            <section class="mt-20 pt-12 border-t border-neutral-200">
                <h2 class="mb-8 font-serif">Sources & Resources</h2>

                <!-- Scientific Sources -->
                {entry.data.sources && entry.data.sources.length > 0 && (
                    <div class="mb-10">
                        <h3 class="mb-6 font-serif text-neutral-900">Peer-Reviewed Sources</h3>
                        <div class="space-y-4 font-sans">
                            {entry.data.sources.map((source) => (
                                <div class="pl-5 border-l-2 border-primary/30">
                                    <a
                                        href={source.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="font-medium block mb-1"
                                    >
                                        {source.title}
                                    </a>
                                    {source.type && (
                                        <span class="text-xs text-neutral-600 uppercase tracking-wider">
                                            {source.type}
                                        </span>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <!-- Further Reading -->
                {entry.data.furtherReading && entry.data.furtherReading.length > 0 && (
                    <div class="mb-10">
                        <h3 class="mb-6 font-serif text-neutral-900">Further Reading</h3>
                        <div class="space-y-5 font-sans">
                            {entry.data.furtherReading.map((reading) => (
                                <div class="p-5 bg-neutral-50 rounded-lg border border-neutral-200 hover:border-primary transition-colors">
                                    <a
                                        href={reading.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="font-semibold text-lg block mb-2"
                                    >
                                        {reading.title}
                                    </a>
                                    {reading.description && (
                                        <p class="text-sm text-neutral-600 leading-relaxed">{reading.description}</p>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <!-- Related Videos -->
                {entry.data.relatedVideos && entry.data.relatedVideos.length > 0 && (
                    <div class="mb-10">
                        <h3 class="mb-6 font-serif text-neutral-900">Related Videos</h3>
                        <div class="space-y-4 font-sans">
                            {entry.data.relatedVideos.map((video) => (
                                <div class="p-5 bg-neutral-50 rounded-lg border border-neutral-200 hover:border-primary transition-colors">
                                    <a
                                        href={video.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="font-medium block"
                                    >
                                        <span class="inline-flex items-start gap-2">
                            <svg class="w-5 h-5 mt-0.5 shrink-0 text-primary" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                                <path d="M6.3 4.7a1 1 0 011.02-.04l8 4.7a1 1 0 010 1.72l-8 4.7A1 1 0 016 15V5.55a1 1 0 01.3-.85z"></path>
                            </svg>
                            <span>{video.title}</span>
                        </span>
                                    </a>
                                    {video.creator && (
                                        <span class="text-sm text-neutral-600 mt-1 block">
                                            by {video.creator}
                                        </span>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                )}

                <div class="mt-10 p-5 rounded-lg bg-neutral-50 border border-neutral-200">
                    <p class="text-sm text-neutral-700 leading-relaxed font-sans">
                        <strong class="text-neutral-900">How we verify.</strong> Every Florecer Mind
                        spotlight is researched and drafted with AI assistance, then reviewed by
                        {` ${reviewer} `}
                        against the primary sources before publishing. Where a study is named above,
                        we link the primary source (or its abstract) alongside reputable summaries
                        for accessible further reading.
                    </p>
                </div>
            </section>
        )}

        <!-- Article Footer -->
        <footer class="mt-16 pt-10 border-t border-neutral-200 font-sans">
            {entry.data.tags && entry.data.tags.length > 0 && (
                <div class="mb-8 flex flex-wrap gap-2">
                    {entry.data.tags.map((tag) => (
                        <a
                            href={`/blog?tag=${encodeURIComponent(tag)}`}
                            class="tag bg-neutral-100 text-neutral-700 hover:bg-primary hover:text-white"
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            )}

            <div class="mb-8">
                <SocialShare title={entry.data.title} url={new URL(Astro.url.pathname, Astro.site).toString()} />
            </div>

            <div class="flex flex-wrap gap-6 justify-between items-center">
                <a href="/blog" class="font-medium inline-flex items-center group">
                    <span class="mr-2 group-hover:-translate-x-1 transition-transform">←</span>
                    Back to All Research
                </a>
                <a href="/newsletter" class="btn btn-primary">
                    Get the weekly spotlight
                </a>
            </div>
        </footer>
    </article>

    <!-- Reading Progress Bar -->
    <div class="reading-progress"></div>

    <!-- Back to Top Button -->
    <button
        id="back-to-top"
        class="back-to-top btn btn-primary btn-circle w-12 h-12 shadow-lg"
        aria-label="Back to top"
    >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
    </button>

    <!-- Structured Data for SEO -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Reading Progress & Back to Top Scripts -->
    <script>
        // Reading progress bar
        function updateProgress() {
            const winScroll = document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            const progressBar = document.querySelector('.reading-progress');
            if (progressBar) {
                progressBar.style.width = scrolled + '%';
            }
        }

        // Back to top button visibility
        function updateBackToTop() {
            const btn = document.getElementById('back-to-top');
            if (btn) {
                if (window.scrollY > 500) {
                    btn.classList.add('visible');
                } else {
                    btn.classList.remove('visible');
                }
            }
        }

        // Combined scroll handler
        function handleScroll() {
            updateProgress();
            updateBackToTop();
        }

        // Debounce for better performance
        let scrollTimeout;
        window.addEventListener('scroll', () => {
            if (scrollTimeout) {
                window.cancelAnimationFrame(scrollTimeout);
            }
            scrollTimeout = window.requestAnimationFrame(() => {
                handleScroll();
            });
        }, { passive: true });

        // Back to top click handler
        document.getElementById('back-to-top')?.addEventListener('click', () => {
            window.scrollTo({
                top: 0,
                behavior: 'smooth'
            });
        });

        // Initialize on page load
        handleScroll();

        // Style checkmarks in article content
        function styleCheckmarks() {
            const prose = document.querySelector('.prose');
            if (!prose) return;

            // Find all text nodes containing checkmarks
            const walker = document.createTreeWalker(
                prose,
                NodeFilter.SHOW_TEXT,
                null
            );

            const nodesToReplace = [];
            let node;
            while (node = walker.nextNode()) {
                if (node.nodeValue && node.nodeValue.includes('✓')) {
                    nodesToReplace.push(node);
                }
            }

            // Replace checkmarks with styled spans
            nodesToReplace.forEach(node => {
                const parent = node.parentNode;
                if (!parent) return;

                const fragment = document.createDocumentFragment();
                const parts = node.nodeValue.split('✓');

                parts.forEach((part, index) => {
                    if (part) {
                        fragment.appendChild(document.createTextNode(part));
                    }
                    if (index < parts.length - 1) {
                        const checkmark = document.createElement('span');
                        checkmark.className = 'checkmark-styled';
                        checkmark.textContent = '✓';
                        fragment.appendChild(checkmark);
                    }
                });

                parent.replaceChild(fragment, node);
            });
        }

        // Run on page load
        styleCheckmarks();
    </script>
</Layout>
